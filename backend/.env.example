# Backend runtime
DATA_DIR=../data
DATABASE_URL=sqlite:///../data/assistant.db
QUALITY_THRESHOLD=80
AGENT_C_CONCURRENCY=4
AGENT_C_MIN_CONCURRENCY=2
AGENT_C_PAGE_TIMEOUT_SECONDS=180
AUTH_ENABLED=true
AUTH_TOKEN_TTL_HOURS=168
AUTH_REGISTRATION_MODE=open
AUTH_REGISTRATION_INVITE_CODE=
AUTH_EMAIL_VERIFICATION_REQUIRED=false
AUTH_EMAIL_CODE_TTL_MINUTES=10
AUTH_EMAIL_CODE_RESEND_SECONDS=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production-123

# SMTP (for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Study Assistant
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# LLM provider: gemini | openai | deepseek | mock
LLM_PROVIDER=gemini
# SECURITY: export GEMINI_API_KEY in shell; avoid persisting plaintext key in .env
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-3.1-pro

# OpenAI provider and PPT/page vision fallback. Prefer OPENAI_API_KEY_PATH for local-only secrets.
OPENAI_API_KEY=
OPENAI_API_KEY_PATH=
OPENAI_MODEL=gpt-5.2
OPENAI_LAST_RESORT_MODEL=gpt-5.2-mini
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek provider. Prefer DEEPSEEK_API_KEY_PATH for local-only secrets.
DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY_PATH=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FALLBACK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com
